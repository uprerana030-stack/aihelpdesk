# =============================================================================
# AI-Powered IT/Admin Helpdesk Router — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- Security ---------------------------------------------------------------
# Authentication uses opaque in-memory session tokens (no JWT, no OAuth2).
# This only controls how long an issued token stays valid.
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- Storage paths ----------------------------------------------------------
# Leave these UNSET to use the absolute, project-root-based defaults (see
# backend/app/core/config.py). Relative paths resolve against the current
# working directory, so running from backend/ vs the project root would point
# at different (empty) data dirs and break RAG retrieval and the DB.
# Uncomment with ABSOLUTE paths only for a custom storage location:
# DATABASE_URL=sqlite:///C:/abs/path/data/helpdesk.db
# CHROMA_PERSIST_DIR=C:/abs/path/data/chroma
# UPLOAD_DIR=C:/abs/path/data/uploads

# --- AI / Multi-agent pipeline ---------------------------------------------
# Confidence threshold for RAG auto-resolution (0.0 - 1.0). NOT hardcoded.
# Tickets >= threshold are auto-resolved; below it they are routed to a team.
AI_CONFIDENCE_THRESHOLD=0.75
# Cosine-similarity threshold for duplicate detection (0.0 - 1.0).
DUPLICATE_SIMILARITY_THRESHOLD=0.85
# Number of KB chunks to retrieve for RAG.
RAG_TOP_K=4

# --- External LLM provider (Gemini only) ------------------------------------
# Leave GEMINI_API_KEY blank to run with graceful degradation (no live AI).
# Get a free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Embedding model. gemini-embedding-001 works on the REST v1beta endpoint
# (3072-dim). If you CHANGE this, re-index so stored vectors match the new
# dimension: python backend/reindex.py
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# --- Outbound TLS -----------------------------------------------------------
# Default (Codespace / normal networks): certificate verification is ON and
# nothing needs to be set here — leave both options commented out.
#
# Only needed when running locally behind a corporate TLS proxy
# (Zscaler/Netskope) that causes:
#   "CERTIFICATE_VERIFY_FAILED: unable to get local issuer certificate"
#   1) RECOMMENDED — keep verification ON by trusting the corporate root CA.
#      Export it to a .pem and point at it:
# CA_BUNDLE=/path/to/corp-root-ca.pem
#   2) INSECURE (dev/demo only) — skip certificate verification entirely:
# DISABLE_SSL_VERIFY=true

# --- Frontend ---------------------------------------------------------------
# Where the Streamlit app reaches the FastAPI backend.
API_BASE_URL=http://localhost:8000
